{
  "manifest_version": 3,
  "name": "SplitSearch Tool",
  "version": "2.0",
  "description": "Split-screen research with one click (or Cmd/Ctrl+Shift+S)",
  "permissions": [
    "contextMenus",
    "tabs",
    "windows",
    "storage",
    "system.display",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "search_selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Search highlighted text in split screen"
    }
  }
}
